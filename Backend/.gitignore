# Dependencies
node_modules

# Environment variables — never commit real secrets
.env
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# One-off/local ops scripts — never pushed. makeAdmin.js talks straight to prod Mongo via
# MONGO_DB_URL with no auth gate beyond having the .env, seedScreenshotUsers.js is local
# Playwright screenshot tooling — blanket-ignoring scripts/ so a future one-off script here
# is safe by default instead of needing a new line added every time
scripts/

# Local-only test infrastructure — kept on disk for local development but never pushed.
# app.local.js is the side-effect-free Express app export __tests__/ requires (mirrors
# index.js's real wiring by hand — keep them in sync if index.js's routes/middleware change).
# Run tests locally with: npx jest --runInBand
__tests__/
jest/
__mocks__/
app.local.js
jest.config.js

